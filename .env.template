# Go Trader environment
# Copy to .env and replace placeholders with real credentials.

# Local development without real Alpaca/Claude credentials.
# Equivalent CLI flag: go run main.go -mock
GO_TRADER_MOCK=false

# Alpaca API Keys - Required for market data and trading when GO_TRADER_MOCK=false
# Get paper keys from https://app.alpaca.markets/paper/dashboard/overview
PAPER_ALPACA_API_KEY=your_key_here
PAPER_ALPACA_SECRET_KEY=your_secret_here

# Claude/Anthropic model suggestions - Optional for Rust trader.
# If unset, trading signals use the deterministic local rule engine.
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_API_KEY is also accepted as a compatibility alias.
CLAUDE_API_KEY=your_claude_key_here

# Live trading keys. Only use deliberately with -paper=false.
LIVE_ALPACA_API_KEY=your_live_key_here
LIVE_ALPACA_SECRET_KEY=your_live_secret_here

# FRED API Key - Optional, enables the live-data overlay on the economic
# cartography (Sahm rule, yield-curve inversion, NFCI, high-yield spreads).
# Without this key the cartography runs formula-only.
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here
